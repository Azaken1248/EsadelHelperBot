# ═══════════════════════════════════════
# Required — Bot will not start without these
# ═══════════════════════════════════════
DISCORD_TOKEN=your-bot-token-here
DISCORD_APPLICATION_ID=your-application-id-here
GUILD_ID=your-guild-server-id-here
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/esadel-bot

# ═══════════════════════════════════════
# Channels — Optional, features disabled if unset
# ═══════════════════════════════════════
APPROVAL_CHANNEL_ID=
REMINDERS_CHANNEL_ID=
LOGS_CHANNEL_ID=
VERIFICATION_CHANNEL_ID=

# ═══════════════════════════════════════
# Structural Roles — Replace with Esadel server role IDs
# ═══════════════════════════════════════
ROLE_OWNER_ID=
ROLE_MOD_ID=
ROLE_CREW_ID=
ROLE_UNVERIFIED_ID=

# ═══════════════════════════════════════
# Specialized Roles — Add per Esadel's team structure
# ═══════════════════════════════════════
# ROLE_ARTIST_ID=
# ROLE_EDITOR_ID=
# ... add as needed

# ═══════════════════════════════════════
# Anti-Bot Verification Gating (reCAPTCHA v2 / hCaptcha)
# ═══════════════════════════════════════
CAPTCHA_SITE_KEY=your-captcha-site-key
CAPTCHA_SECRET_KEY=your-captcha-secret-key
WEB_PORTAL_URL=https://esadel.azaken.com

# ═══════════════════════════════════════
# Web Portal Settings
# ═══════════════════════════════════════
WEBSITE_PORT=3000
ANALYTICS_JWT_SECRET=your-analytics-jwt-secret

# ═══════════════════════════════════════
# Reminder System — Defaults are usually fine
# ═══════════════════════════════════════
REMINDERS_ENABLED=true
REMINDER_OFFSETS_MINUTES=1440,360,60,0
# REMINDER_POLL_INTERVAL_MS=30000
# REMINDER_BATCH_SIZE=25
# REMINDER_LOCK_DURATION_MS=60000
# REMINDER_MAX_ATTEMPTS=5

# ═══════════════════════════════════════
# Extension Rules
# ═══════════════════════════════════════
# MAX_STANDARD_EXTENSIONS=
BLOCK_TIME_LIMITED_AUTO_EXTENSION=true
